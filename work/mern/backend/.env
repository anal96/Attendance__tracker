# Email Configuration (SMTP)
# Fill in your email credentials below

# SMTP Server Configuration
SMTP_HOST=
SMTP_PORT=
# Your Email Credentials
# For Gmail: Use your email address
SMTP_USE=

# For Gmail: Use the App Password you generated (not your regular password)
# Generate App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_PASS=

# Instructions:
# 1. Replace SMTP_USER with your email address (e.g., your-email@gmail.com)
# 2. Replace SMTP_PASS with the App Password you generated from Google
# 3. Save this file
# 4. Restart your backend server
